# Domain
DOMAIN=yourdomain.com
EMAIL=your@email.com

# Docker Hub
DOCKERHUB_USERNAME=your-dockerhub-username

# Timezone
TZ=Asia/Phnom_Penh

# Active Directory
AD_SERVER_IP=192.168.1.10
AD_BASE_DN=DC=yourdomain,DC=com
AD_USER_OU=OU=Users
AD_GROUP_OU=OU=Groups
AD_SERVICE_ACCOUNT=CN=svc-authelia,OU=ServiceAccounts,DC=yourdomain,DC=com
AD_SERVICE_PASSWORD=your-ad-service-account-password

# Authelia Secrets
AUTHELIA_JWT_SECRET=your-very-long-random-secret-here
AUTHELIA_SESSION_SECRET=another-long-random-secret