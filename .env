# MariaDB
MARIADB_ROOT_PASSWORD=rootpassword
MARIADB_DATABASE=uptimekuma
MARIADB_USER=kuma
MARIADB_PASSWORD=kumapass

# Uptime Kuma → MariaDB connection
KU_DB_TYPE=mysql
KU_DB_HOST=kuma-db
KU_DB_PORT=3306
KU_DB_NAME=uptimekuma
KU_DB_USER=kuma
KU_DB_PASSWORD=kumapass
